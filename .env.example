# Copy this file to .env.local for local development.
# On Vercel/Netlify, set this in the project's environment variables instead.
#
# Get a free key at https://openrouter.ai (Profile -> Keys -> Create Key)
#
# NOTE: because this is a client-only app with no backend, this key ships
# inside the browser bundle and is visible to anyone who opens devtools.
# Don't reuse this key anywhere sensitive — free-tier OpenRouter keys have
# low rate limits, which bounds the worst case, but this is not a secure
# way to hold a real secret long-term.
VITE_OPENROUTER_API_KEY=your_key_here
